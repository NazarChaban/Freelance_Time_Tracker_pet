# DB
POSTGRES_PASSWORD=postgres_password
POSTGRES_USER=postgres_user
POSTGRES_DB=postgres_db
POSTGRES_HOST=your_postgres_host | localhost | db-postgres # db-postgres is the name of the postgres service in docker-compose.yml
POSTGRES_PORT=postgres_port

# Django
SECRET_KEY=your_secret_key
DEBUG=True | False
# If you are using docker-compose:
CREATE_SUPERUSER=True | False
SUPERUSER_USERNAME=admin_username
SUPERUSER_EMAIL=admin_mail@mail.com
SUPERUSER_PASSWORD=admin_password

# Email
EMAIL_BACKEND=email.service.provider
EMAIL_HOST=smtp.your-email.com
EMAIL_PORT=email_port
EMAIL_HOST_USER=your_email_username
EMAIL_HOST_PASSWORD=your_email_password
EMAIL_USE_TLS=True | False
EMAIL_FROM=${EMAIL_HOST_USER}

# REDIS
REDIS_PASSWORD=redis
REDIS_HOST=your_redis_host | localhost | redis # redis is the name of the redis service in docker-compose.yml
REDIS_PORT=redis_port
REDIS_DB=redis_db_number
